{
  "name": "media-guard",
  "private": true,
  "type": "module",
  "workspaces": [
    "api",
    "scripts/skill-generator"
  ],
  "scripts": {
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "api:dev": "npm run --workspace=media-guard-api dev",
    "skill:generate": "cd scripts/skill-generator && tsx src/index.ts",
    "stt:build": "./scripts/build-stt.sh",
    "stt:serve": "python scripts/serve-stt.py",
    "skill:generate:datasets": "cd scripts/skill-generator && tsx src/generate-from-datasets.ts",
    "skill:evaluate": "cd scripts/skill-generator && tsx src/evaluate.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  }
}