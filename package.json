{
  "name": "media-guard",
  "private": true,
  "type": "module",
  "workspaces": [
    "api",
    "scripts/skill-generator"
  ],
  "scripts": {
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "api:dev": "npm run --workspace=media-guard-api dev",
    "skill:generate": "cd scripts/skill-generator && tsx src/index.ts",
    "stt:build": "./scripts/build-stt.sh",
    "stt:serve": "python scripts/serve-stt.py",
    "extension:icons": "./scripts/generate-extension-icons.sh",
    "skill:generate:datasets": "cd scripts/skill-generator && tsx src/generate-from-datasets.ts",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "web:preview": "cd web && npm run preview",
    "extension:build": "./scripts/build-extension.sh",
    "skill:evaluate": "cd scripts/skill-generator && tsx src/evaluate.ts",
    "skill:evaluate:benchmark": "cd scripts/skill-generator && tsx src/evaluate-benchmark.ts",
    "skill:definitions": "cd scripts/skill-generator && tsx src/run-definitions.ts",
    "skill:benchmark": "cd scripts/skill-generator && tsx src/benchmark.ts",
    "skill:benchmark:sync": "cd scripts/skill-generator && tsx src/sync-dataset.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@hono/node-ws": "^1.3.0",
    "@mistralai/mistralai": "^1.14.1",
    "@prisma/client": "^6.0.0"
  },
  "author": "AntoineFrau",
  "license": "MIT"
}