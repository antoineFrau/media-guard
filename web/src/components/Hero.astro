---
interface Props {
	videoId?: string;
}

const { videoId } = Astro.props;
---

<header class="overflow-visible border-b border-white/10 bg-gradient-to-b from-bg to-bg-elevated py-16 text-center" id="demo-video">
	<div class="mx-auto max-w-[42rem]">
		<h1 class="mb-4 text-[clamp(1.75rem,4vw,2.5rem)] font-bold leading-tight text-text">How often do you spot manipulation in the videos you watch?</h1>
		<p class="mb-2 text-lg text-text-muted">Propaganda techniques are hard to detect in real time. <strong class="text-accent">MediaGuard detects them as you watch</strong> — SponsorBlock-style segment markers and contextual overlays on YouTube.</p>
		<p class="mb-8 text-[0.9375rem] text-text-muted opacity-90">Open source. Your key, your data.</p>
		<div class="flex flex-wrap justify-center gap-4">
			<a href="#install" class="btn-primary text-[0.9375rem]">Install for Firefox</a>
		</div>
	</div>
	<div class="mx-auto mt-8 max-w-[56rem] px-6 pb-4">
		<div class="rounded-xl shadow-[0_4px_24px_rgba(0,0,0,0.4),0_8px_48px_rgba(0,0,0,0.25)]">
			<div class={`aspect-video overflow-hidden rounded-xl bg-bg ${!videoId ? 'flex flex-col items-center justify-center border-2 border-dashed border-white/20' : ''}`} aria-label={videoId ? undefined : 'Placeholder for hackathon demo video'}>
				{videoId ? (
					<iframe
						src={`https://www.youtube.com/embed/${videoId}?rel=0`}
						title="MediaGuard demo video"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
						allowfullscreen
						class="size-full border-0"
					/>
				) : (
					<>
						<p class="text-[0.9375rem]">Hackathon demo video</p>
						<p class="text-[0.8125rem] opacity-60">Add your YouTube video ID to the Hero component</p>
					</>
				)}
			</div>
		</div>
	</div>
</header>
