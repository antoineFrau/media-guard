---
const base = import.meta.env.BASE_URL;
---

<header class="border-b border-white/10 bg-bg px-6 py-4">
	<nav class="mx-auto flex max-w-6xl items-center justify-between">
		<a href={base || '/'} class="text-lg font-bold text-text hover:text-accent">MediaGuard</a>
		<div class="flex gap-6">
			<a href={base || '/'} class="text-[0.9375rem] text-text-muted hover:text-accent">Home</a>
			<a href={`${base}team/`} class="text-[0.9375rem] text-text-muted hover:text-accent">Team</a>
			<a href={`${base}documentation/`} class="text-[0.9375rem] text-text-muted hover:text-accent">Documentation</a>
			<a href="https://github.com/zenocode/media-guard" target="_blank" rel="noopener" class="text-[0.9375rem] text-text-muted hover:text-accent">GitHub</a>
		</div>
	</nav>
</header>
