---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = 'MediaGuard — Spot manipulation in YouTube videos', description = 'AI-powered detection of propaganda techniques in YouTube videos. SponsorBlock-style segment markers and contextual overlays. Open source. Your key, your data.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}logo.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen bg-bg text-text font-sans text-base leading-relaxed antialiased">
		<slot />
	</body>
</html>
