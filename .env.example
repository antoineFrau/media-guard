# MediaGuard Environment
# Copy to .env and fill in values as needed.

# --- Required ---
DATABASE_URL="postgresql://mediaguard:mediaguard@localhost:5432/mediaguard"

# --- API / Analysis ---
# Mistral API key: for server-side analysis, Mistral Voxtral STT proxy, and skill generation.
# If unset, clients must send X-Mistral-API-Key header per request (BYOK).
# MISTRAL_API_KEY=...

# --- STT (ElevenLabs) ---
# Only needed when client doesn't provide key for ElevenLabs speech-to-text.
# ELEVENLABS_API_KEY=...

# --- Langfuse (LLM tracing) ---
# Optional. When set, /analyze and /video/:id/analysis requests are traced.
# Run `docker compose up -d` to start self-hosted Langfuse at http://localhost:3100.
# LANGFUSE_SECRET_KEY=...
# LANGFUSE_PUBLIC_KEY=...
# LANGFUSE_BASE_URL=http://localhost:3100
